    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.43.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
